# ============================================================
# P2E Bible — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

NODE_ENV=production
PORT=4080

# ── REQUIRED ─────────────────────────────────────────────────
# Anthropic (Claude) — powers Scout and Detective agents
ANTHROPIC_API_KEY=sk-ant-...

# Admin panel password — set this to anything strong
ADMIN_SECRET=change-me-to-something-strong

# ── DATABASE ─────────────────────────────────────────────────
DATABASE_PATH=./p2ebible.db

# ── SCOUT: Optional data sources ─────────────────────────────
# Twitter/X — get Bearer Token from developer.twitter.com
TWITTER_BEARER_TOKEN=

# Telegram — create a bot at t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_IDS=   # comma-separated channel IDs to monitor

# ── AFFILIATE IDs (Clerk) ─────────────────────────────────────
# Update these in Admin > Affiliate Links instead of here.
# These are fallbacks if not set via admin.
AFFILIATE_BASE_URL=https://p2ebible.com/go

# ── HUB CONNECTION (EarnHQ) ───────────────────────────────────
# Leave blank until EarnHQ is deployed.
# When ready, set these and the Clerk will start pinging the Hub.
EARNHQ_HUB_URL=
EARNHQ_HUB_SECRET=
